        <mxCell id="health-check" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="CheckHealth()&#xa;Deployment / DaemonSet ready?" vertex="1">
