        <mxCell id="helm-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" value="helm.Manager&lt;br&gt;&lt;br&gt;• Add chart repo&lt;br&gt;• helm install / upgrade&lt;br&gt;• Wait for ready (5m timeout)" vertex="1">
